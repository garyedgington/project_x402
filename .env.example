# Project x402 — SchemaCheck Agent local configuration

# disabled: no payment required. Use for local dev and tests.
# placeholder: requires X-Payment-Token header with the token below.
SCHEMACHECK_PAYMENT_MODE=disabled

# Static token used only by the placeholder payment gate.
# Real x402 payment verification replaces this in Phase 3.
SCHEMACHECK_PLACEHOLDER_PAYMENT_TOKEN=test-payment-token

# true/false request logging middleware.
SCHEMACHECK_LOG_REQUESTS=true
